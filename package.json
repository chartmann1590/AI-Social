{
  "name": "aisocial",
  "version": "1.1.0",
  "main": "index.ts",
  "scripts": {
    "start": "cross-env NODE_ENV=development expo start --dev-client",
    "android": "cross-env NODE_ENV=development CI=true expo run:android",
    "android:release": "cross-env NODE_ENV=production CI=true expo run:android --variant release",
    "android:deploy": "cross-env NODE_ENV=production CI=true cmd /c \"cd android && gradlew.bat installRelease\"",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.9.0",
    "@react-navigation/native": "^7.1.26",
    "@react-navigation/native-stack": "^7.9.0",
    "expo": "~54.0.30",
    "expo-constants": "^18.0.12",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-google-mobile-ads": "^16.3.3",
    "react-native-paper": "^5.14.5",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "~4.16.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "cross-env": "^10.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
