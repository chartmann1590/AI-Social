.DS_Store
*.pem

# local env files
.env*.local
.env
.env.*
src/config.ts
AGENTS.md

# typescript
*.tsbuildinfo

# generated native folders
/ios

# android/ IS tracked (see below) — it's the real native project, not a disposable
# `expo prebuild` regeneration. Only its build outputs/local machine state are ignored.
/android/local.properties
/android/app/google-services.json
/android/.gradle/
/android/.idea/
/android/*.iml
/android/build/
/android/app/build/
/android/app/.cxx/
/android/**/build/
/android/**/.cxx/

# coverage and build artifacts (generated by jest / gradle / build scripts)
coverage/
*.log
release-build.log
build.log
metro.log
install-log*.txt
adb_logcat*.txt

# debug screenshots and ui dumps captured during development; not part of the project
adb_*.png
adb_*.txt
ui_*.xml
ui-*.xml
check.xml
device_*.png
device-*.png
pixel_*.png
err.png
err2.png
err3.png
screen.png
aisocial_*.png
onboarding_*.png

# do not commit the 200 MB build artifact — releases are published via GitHub Releases
play-store/app-release.apk
play-store/*.aab

# Cloudflare Worker local dev state/secrets (real secrets live in `wrangler secret put`)
cloudflare/**/.wrangler
cloudflare/**/.dev.vars
